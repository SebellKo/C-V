{
  "manifest_version": 3,
  "name": "C:V",
  "description": "Multi Copy/Paste",
  "version": "1.0",
  "icons": {
    "16": "images/icon/icon-16.png",
    "32": "images/icon/icon-32.png",
    "48": "images/icon/icon-48.png",
    "128": "images/icon/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/icon/icon-16.png",
      "32": "images/icon/icon-32.png",
      "48": "images/icon/icon-48.png",
      "128": "images/icon/icon-128.png"
    }
  },
  "permissions": ["activeTab", "scripting"],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+B",
        "mac": "Command+B"
      }
    }
  }
}
